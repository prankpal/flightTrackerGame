# Twilio credentials (get from twilio.com/console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Your phone number to receive SMS alerts
YOUR_PHONE_NUMBER=

# OpenSky Network (optional - free account gives more API calls)
# Register at opensky-network.org for higher rate limits
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Server config
PORT=3000

# How often to poll for flights (in seconds). 
# Free OpenSky: keep at 60. With account: can do 20.
POLL_INTERVAL_SECONDS=60

# Max altitude in meters to alert on (12000m ≈ 40,000ft, use 4000 for "low/visible" planes)
MAX_ALTITUDE_METERS=4000

# Radius in km to search around your location
SEARCH_RADIUS_KM=15
